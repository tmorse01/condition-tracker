{
  "name": "condition-tracker",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "typescript-eslint": "^8.46.2"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @condition-tracker/api --filter @condition-tracker/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "db:migrate": "pnpm --filter @condition-tracker/db migrate",
    "db:seed": "pnpm --filter @condition-tracker/db seed",
    "deploy:preflight": "pnpm install --frozen-lockfile && pnpm build && pnpm typecheck && pnpm lint",
    "deploy:api": "railway up --service \"@condition-tracker/api\"",
    "deploy:web": "railway up --service \"@condition-tracker/web\"",
    "deploy:all": "pnpm deploy:preflight && pnpm deploy:api && pnpm deploy:web",
    "deploy:logs:api": "railway logs --service \"@condition-tracker/api\"",
    "deploy:logs:web": "railway logs --service \"@condition-tracker/web\""
  }
}
