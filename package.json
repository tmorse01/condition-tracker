{
  "name": "condition-tracker",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "typescript-eslint": "^8.46.2"
  },
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "start": "pnpm --filter @condition-tracker/api start",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm --filter @condition-tracker/api test",
    "db:migrate": "pnpm --filter @condition-tracker/db migrate",
    "db:seed": "pnpm --filter @condition-tracker/db seed",
    "deploy:preflight": "pnpm install --frozen-lockfile && pnpm build && pnpm typecheck && pnpm lint",
    "deploy:api": "railway up --detach",
    "deploy:all": "pnpm deploy:preflight && pnpm deploy:api",
    "deploy:logs:api": "railway logs"
  }
}
